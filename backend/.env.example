# Server
NODE_ENV=development
PORT=8080

# Supabase Postgres (pooled or direct URL)
DATABASE_URL=postgresql://user:password@host:5432/db

# Cross-origin (CSV) — set to your deployed frontend URL in prod
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Sentinel OIDC (https://github.com/mohdaffankhan/sentinel)
SENTINEL_ISSUER=https://your-sentinel-instance.example.com
CLIENT_ID=client_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLIENT_SECRET=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENTINEL_REDIRECT_URI=http://localhost:8080/auth/sentinel/callback

# Secrets (>= 32 chars). Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-hex
COOKIE_SECRET=replace-me-with-a-long-random-hex

# Salt for hashing respondent IPs in the responses table (>= 16 chars).
IP_HASH_SALT=replace-me-with-a-random-hex
